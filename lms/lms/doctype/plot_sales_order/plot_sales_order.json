{
 "doctype": "DocType",
 "name": "Plot Sales Order",
 "module": "Lms",
 "autoname": "naming_series:",
 "is_submittable": 1,
 "track_changes": 1,
 "title_field": "customer",
 "search_fields": "customer,plot,control_number,status",
 "field_order": [
  "naming_series",
  "order_section",
  "customer",
  "plot_application",
  "plot",
  "acquisition_name",
  "land_acquisition",
  "order_date",
  "col_break_1",
  "status",
  "payment_completion_days",
  "payment_deadline",
  "control_number",
  "plot_contract",
  "financials_section",
  "selling_price",
  "booking_fee_percent",
  "government_share_percent",
  "col_break_2",
  "booking_fee_amount",
  "balance_due",
  "payment_schedule_section",
  "payment_schedule",
  "payment_summary_section",
  "total_contract_value",
  "total_paid",
  "col_break_3",
  "total_outstanding",
  "government_fee_withheld",
  "notes_section",
  "notes",
  "amended_from"
 ],
 "fields": [
  {
   "fieldname": "naming_series",
   "fieldtype": "Select",
   "label": "Series",
   "options": "PSO-.YYYY.-.####"
  },
  {
   "fieldname": "order_section",
   "fieldtype": "Section Break",
   "label": "Sales Order Details"
  },
  {
   "fieldname": "customer",
   "fieldtype": "Link",
   "label": "Customer",
   "options": "Customer",
   "reqd": 1,
   "in_list_view": 1
  },
  {
   "fieldname": "plot",
   "fieldtype": "Link",
   "label": "Plot",
   "options": "Plot Master",
   "reqd": 1,
   "in_list_view": 1,
   "description": "Available/Reserved plot. Auto-filled when Plot Application is selected."
  },
  {
   "fieldname": "acquisition_name",
   "fieldtype": "Data",
   "label": "Acquisition Name",
   "read_only": 1,
   "description": "Auto-filled from the Land Acquisition"
  },
  {
   "fieldname": "land_acquisition",
   "fieldtype": "Link",
   "label": "Land Acquisition",
   "options": "Land Acquisition",
   "read_only": 1,
   "description": "Auto-filled from the selected plot"
  },
  {
   "fieldname": "order_date",
   "fieldtype": "Date",
   "label": "Order Date",
   "reqd": 1,
   "in_list_view": 1
  },
  {
   "fieldname": "col_break_1",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "status",
   "fieldtype": "Select",
   "label": "Status",
   "options": "Draft\nOpen\nConverted\nCancelled",
   "default": "Draft",
   "read_only": 1,
   "in_list_view": 1,
   "in_standard_filter": 1
  },
  {
   "fieldname": "payment_completion_days",
   "fieldtype": "Int",
   "label": "Payment Completion Days",
   "reqd": 1,
   "default": "90",
   "in_list_view": 1,
   "description": "Number of days from order date the customer has to complete full payment"
  },
  {
   "fieldname": "payment_deadline",
   "fieldtype": "Date",
   "label": "Payment Deadline",
   "read_only": 1,
   "description": "Auto-filled from order date + payment completion days"
  },
  {
   "fieldname": "control_number",
   "fieldtype": "Data",
   "label": "TCB Control Number",
   "read_only": 1,
   "description": "Generated on submission \u2014 customer uses this at TCB bank to make payments",
   "in_list_view": 1
  },
  {
   "fieldname": "plot_contract",
   "fieldtype": "Link",
   "label": "Plot Contract",
   "options": "Plot Contract",
   "read_only": 1,
   "description": "Auto-created when first payment is confirmed"
  },
  {
   "fieldname": "plot_application",
   "fieldtype": "Link",
   "label": "Plot Application",
   "options": "Plot Application",
   "description": "Select a submitted Paid Plot Application. SO fields auto-fill from it (except Booking/Government %)."
  },
  {
   "fieldname": "financials_section",
   "fieldtype": "Section Break",
   "label": "Financials"
  },
  {
   "fieldname": "selling_price",
   "fieldtype": "Float",
   "label": "Selling Price (TZS)",
   "read_only": 1,
   "description": "Auto-filled from Plot Master"
  },
  {
   "fieldname": "booking_fee_percent",
   "fieldtype": "Percent",
   "label": "Booking Fee %",
   "reqd": 1,
   "description": "Percentage of selling price required as booking fee"
  },
  {
   "fieldname": "government_share_percent",
   "fieldtype": "Percent",
   "label": "Government Share %",
   "reqd": 1,
   "description": "Government fee percentage \u2014 posted only at full payment completion"
  },
  {
   "fieldname": "col_break_2",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "booking_fee_amount",
   "fieldtype": "Float",
   "label": "Booking Fee Amount (TZS)",
   "read_only": 1
  },
  {
   "fieldname": "balance_due",
   "fieldtype": "Float",
   "label": "Balance Due (TZS)",
   "read_only": 1
  },
  {
   "fieldname": "payment_schedule_section",
   "fieldtype": "Section Break",
   "label": "Payment Schedule"
  },
  {
   "fieldname": "payment_schedule",
   "fieldtype": "Table",
   "label": "Payment Schedule",
   "options": "Plot Contract Payment"
  },
  {
   "fieldname": "payment_summary_section",
   "fieldtype": "Section Break",
   "label": "Payment Summary"
  },
  {
   "fieldname": "total_contract_value",
   "fieldtype": "Float",
   "label": "Total Contract Value (TZS)",
   "read_only": 1
  },
  {
   "fieldname": "total_paid",
   "fieldtype": "Float",
   "label": "Total Paid (TZS)",
   "read_only": 1
  },
  {
   "fieldname": "col_break_3",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "total_outstanding",
   "fieldtype": "Float",
   "label": "Total Outstanding (TZS)",
   "read_only": 1
  },
  {
   "fieldname": "government_fee_withheld",
   "fieldtype": "Float",
   "label": "Expected Government Fee (TZS)",
   "read_only": 1,
   "description": "Selling price \u00d7 government share % \u2014 posted only at full payment completion"
  },
  {
   "fieldname": "notes_section",
   "fieldtype": "Section Break",
   "label": "Notes"
  },
  {
   "fieldname": "notes",
   "fieldtype": "Long Text",
   "label": "Notes"
  },
  {
   "fieldname": "amended_from",
   "fieldtype": "Link",
   "label": "Amended From",
   "options": "Plot Sales Order",
   "read_only": 1,
   "print_hide": 1
  }
 ],
 "permissions": [
  {
   "role": "Administrator",
   "read": 1,
   "write": 1,
   "create": 1,
   "delete": 1,
   "submit": 1,
   "cancel": 1,
   "amend": 1
  },
  {
   "role": "Sales",
   "read": 1,
   "write": 1,
   "create": 1,
   "submit": 1
  },
  {
   "role": "Finance",
   "read": 1
  },
  {
   "role": "Auditor",
   "read": 1
  }
 ],
 "states": [
  {
   "color": "Grey",
   "title": "Draft"
  },
  {
   "color": "Yellow",
   "title": "Open"
  },
  {
   "color": "Green",
   "title": "Converted"
  },
  {
   "color": "Red",
   "title": "Cancelled"
  }
 ],
 "naming_rule": "By \"Naming Series\" field",
 "row_format": "Dynamic",
 "sort_field": "modified",
 "sort_order": "DESC"
}
