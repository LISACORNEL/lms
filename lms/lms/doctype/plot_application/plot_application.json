{
 "doctype": "DocType",
 "name": "Plot Application",
 "module": "Lms",
 "autoname": "naming_series:",
 "is_submittable": 1,
 "track_changes": 1,
 "title_field": "customer",
 "search_fields": "customer,plot,status",
 "field_order": [
  "naming_series",
  "application_section",
  "customer",
  "plot",
  "acquisition_name",
  "land_acquisition",
  "application_date",
  "col_break_1",
  "status",
  "application_fee",
  "unpaid_validity_days",
  "validity_days",
  "expiry_date",
  "fee_section",
  "payment_date",
  "reference_no",
  "col_break_2",
  "sales_invoice",
  "payment_entry",
  "links_section",
  "plot_sales_order",
  "notes_section",
  "notes",
  "amended_from"
 ],
 "fields": [
  {
   "fieldname": "naming_series",
   "fieldtype": "Select",
   "label": "Series",
   "options": "PA-.YYYY.-.####"
  },
  {
   "fieldname": "application_section",
   "fieldtype": "Section Break",
   "label": "Application Details"
  },
  {
   "fieldname": "customer",
   "fieldtype": "Link",
   "label": "Customer",
   "options": "Customer",
   "reqd": 1,
   "in_list_view": 1
  },
  {
   "fieldname": "plot",
   "fieldtype": "Link",
   "label": "Plot",
   "options": "Plot Master",
   "reqd": 1,
   "in_list_view": 1,
   "description": "Only Available plots can be selected"
  },
  {
   "fieldname": "acquisition_name",
   "fieldtype": "Data",
   "label": "Acquisition Name",
   "read_only": 1,
   "description": "Auto-filled from the Land Acquisition"
  },
  {
   "fieldname": "land_acquisition",
   "fieldtype": "Link",
   "label": "Land Acquisition",
   "options": "Land Acquisition",
   "read_only": 1,
   "description": "Auto-filled from the selected plot"
  },
  {
   "fieldname": "application_date",
   "fieldtype": "Date",
   "label": "Application Date",
   "reqd": 1,
   "default": "Today",
   "in_list_view": 1
  },
  {
   "fieldname": "col_break_1",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "status",
   "fieldtype": "Select",
   "label": "Status",
   "options": "Draft\nSubmitted\nPaid\nConverted\nExpired\nCancelled",
   "default": "Draft",
   "read_only": 1,
   "in_list_view": 1,
   "in_standard_filter": 1
  },
  {
   "fieldname": "application_fee",
   "fieldtype": "Float",
   "label": "Application Fee (TZS)",
   "read_only": 1,
   "description": "Auto-filled from LMS Settings"
  },
  {
   "fieldname": "unpaid_validity_days",
   "fieldtype": "Int",
   "label": "Pre-Payment Validity (Days)",
   "read_only": 1,
   "description": "Auto-filled from LMS Settings (Unpaid Application Expiry Days)"
  },
  {
   "fieldname": "validity_days",
   "fieldtype": "Int",
   "label": "Post-Payment Validity (Days)",
   "read_only": 1,
   "description": "Auto-filled from LMS Settings (Application Fee Validity Days)"
  },
  {
   "fieldname": "expiry_date",
   "fieldtype": "Date",
   "label": "Expiry Date",
   "read_only": 1,
   "description": "Auto-calculated: payment date + validity days. Plot released back to Available after this date."
  },
  {
   "fieldname": "fee_section",
   "fieldtype": "Section Break",
   "label": "Payment Details"
  },
  {
   "fieldname": "payment_date",
   "fieldtype": "Date",
   "label": "Payment Date",
   "read_only": 1
  },
  {
   "fieldname": "reference_no",
   "fieldtype": "Data",
   "label": "Payment Reference No",
   "read_only": 1
  },
  {
   "fieldname": "col_break_2",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "sales_invoice",
   "fieldtype": "Link",
   "label": "Sales Invoice",
   "options": "Sales Invoice",
   "read_only": 1,
   "description": "SI created for the application fee"
  },
  {
   "fieldname": "payment_entry",
   "fieldtype": "Link",
   "label": "Payment Entry",
   "options": "Payment Entry",
   "read_only": 1,
   "description": "Payment recorded against the application fee SI"
  },
  {
   "fieldname": "links_section",
   "fieldtype": "Section Break",
   "label": "Linked Documents"
  },
  {
   "fieldname": "plot_sales_order",
   "fieldtype": "Link",
   "label": "Plot Sales Order",
   "options": "Plot Sales Order",
   "read_only": 1,
   "description": "Auto-created when you click Create Sales Order after payment"
  },
  {
   "fieldname": "notes_section",
   "fieldtype": "Section Break",
   "label": "Notes"
  },
  {
   "fieldname": "notes",
   "fieldtype": "Long Text",
   "label": "Notes"
  },
  {
   "fieldname": "amended_from",
   "fieldtype": "Link",
   "label": "Amended From",
   "options": "Plot Application",
   "read_only": 1,
   "print_hide": 1
  }
 ],
 "permissions": [
  {
   "role": "Administrator",
   "read": 1,
   "write": 1,
   "create": 1,
   "delete": 1,
   "submit": 1,
   "cancel": 1,
   "amend": 1
  },
  {
   "role": "Sales",
   "read": 1,
   "write": 1,
   "create": 1,
   "submit": 1
  },
  {
   "role": "Finance",
   "read": 1
  },
  {
   "role": "Auditor",
   "read": 1
  }
 ],
 "states": [
  {
   "color": "Grey",
   "title": "Draft"
  },
  {
   "color": "Blue",
   "title": "Submitted"
  },
  {
   "color": "Green",
   "title": "Paid"
  },
  {
   "color": "Purple",
   "title": "Converted"
  },
  {
   "color": "Red",
   "title": "Expired"
  },
  {
   "color": "Red",
   "title": "Cancelled"
  }
 ],
 "naming_rule": "By \"Naming Series\" field",
 "sort_field": "modified",
 "sort_order": "DESC"
}
