{
 "doctype": "DocType",
 "name": "Land Acquisition",
 "module": "Lms",
 "autoname": "naming_series:",
 "naming_series": "LACQ-.YYYY.-.####",
 "title_field": "acquisition_name",
 "search_fields": "acquisition_name,status,region",
 "is_submittable": 1,
 "track_changes": 1,
 "fields": [
  {
   "fieldname": "naming_series",
   "fieldtype": "Select",
   "label": "Series",
   "options": "LACQ-.YYYY.-.####"
  },
  {
   "fieldname": "basic_section",
   "fieldtype": "Section Break",
   "label": "Land Details"
  },
  {
   "fieldname": "acquisition_name",
   "fieldtype": "Data",
   "label": "Acquisition Name",
   "reqd": 1,
   "description": "A short descriptive name e.g.The Ubungo Project"
  },
  {
   "fieldname": "acquisition_date",
   "fieldtype": "Date",
   "label": "Acquisition Date",
   "reqd": 1
  },
  {
   "fieldname": "col_break_1",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "status",
   "fieldtype": "Select",
   "label": "Status",
   "options": "Draft\nPending Approval\nApproved\nSubdivided",
   "default": "Draft",
   "read_only": 1
  },
  {
   "fieldname": "location_section",
   "fieldtype": "Section Break",
   "label": "Location"
  },
  {
   "fieldname": "region",
   "fieldtype": "Select",
   "label": "Region",
   "reqd": 1,
   "options": "\nArusha\nDar es Salaam\nDodoma\nGeita\nIringa\nKagera\nKatavi\nKigoma\nKilimanjaro\nLindi\nManyara\nMara\nMbeya\nMorogoro\nMtwara\nMwanza\nNjombe\nPwani\nRukwa\nRuvuma\nShinyanga\nSimiyu\nSingida\nSongwe\nTabora\nTanga\nKaskazini Pemba\nKaskazini Unguja\nKusini Pemba\nKusini Unguja\nMjini Magharibi"
  },
  {
   "fieldname": "district",
   "fieldtype": "Data",
   "label": "District",
   "reqd": 1
  },
  {
   "fieldname": "col_break_2",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "ward",
   "fieldtype": "Data",
   "label": "Ward"
  },
  {
   "fieldname": "latitude",
   "fieldtype": "Float",
   "label": "Latitude",
   "description": "Optional center-point latitude for this acquisition"
  },
  {
   "fieldname": "longitude",
   "fieldtype": "Float",
   "label": "Longitude",
   "description": "Optional center-point longitude for this acquisition"
  },
  {
   "fieldname": "location_description",
   "fieldtype": "Small Text",
   "label": "Location Description"
  },
  {
   "fieldname": "land_details_section",
   "fieldtype": "Section Break",
   "label": "Land Information"
  },
  {
   "fieldname": "total_area_sqm",
   "fieldtype": "Float",
   "label": "Total Area (sqm)",
   "reqd": 1
  },
  {
   "fieldname": "land_use_type",
   "fieldtype": "Select",
   "label": "Land Use Type",
   "options": "Residential\nCommercial\nAgricultural\nMixed",
   "reqd": 1
  },
  {
   "fieldname": "col_break_3",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "title_deed_number",
   "fieldtype": "Data",
   "label": "Title Deed Number"
  },
  {
   "fieldname": "sales_defaults_section",
   "fieldtype": "Section Break",
   "label": "Sales Defaults"
  },
  {
   "fieldname": "booking_fee_percent",
   "fieldtype": "Percent",
   "label": "Booking Fee %",
   "reqd": 1,
   "default": "10",
   "description": "Default booking fee percentage for plots created under this acquisition"
  },
  {
   "fieldname": "government_share_percent",
   "fieldtype": "Percent",
   "label": "Government Share %",
   "reqd": 1,
   "default": "0",
   "description": "Default government share percentage for plots created under this acquisition"
  },
  {
   "fieldname": "sales_defaults_col_break",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "payment_completion_days",
   "fieldtype": "Int",
   "label": "Payment Completion Days",
   "reqd": 1,
   "default": "30",
   "description": "Default number of days allowed to complete plot payment after the fee stage"
  },
  {
   "fieldname": "seller_section",
   "fieldtype": "Section Break",
   "label": "Seller Information"
  },
  {
   "fieldname": "seller",
   "fieldtype": "Link",
   "label": "Seller (Supplier)",
   "options": "Supplier",
   "reqd": 1,
   "description": "Must exist as a Supplier in ERPNext — used for journal entry on approval"
  },
  {
   "fieldname": "seller_id_type",
   "fieldtype": "Select",
   "label": "Seller ID Type",
   "options": "National ID\nPassport\nCompany Registration"
  },
  {
   "fieldname": "col_break_4",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "seller_id_number",
   "fieldtype": "Data",
   "label": "Seller ID Number"
  },
  {
   "fieldname": "cost_section",
   "fieldtype": "Section Break",
   "label": "Acquisition Cost"
  },
  {
   "fieldname": "cost_items",
   "fieldtype": "Table",
   "label": "Cost Breakdown",
   "options": "Land Acquisition Cost Item"
  },
  {
   "fieldname": "total_acquisition_cost",
   "fieldtype": "Float",
   "label": "Total Acquisition Cost",
   "read_only": 1,
   "description": "Auto-calculated from cost breakdown rows above"
  },
  {
   "fieldname": "acquisition_currency",
   "fieldtype": "Link",
   "label": "Currency",
   "options": "Currency",
   "reqd": 1,
   "default": "TZS"
  },
  {
   "fieldname": "col_break_5",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "exchange_rate",
   "fieldtype": "Float",
   "label": "Exchange Rate",
   "default": "1.0",
   "description": "Leave as 1.0 if currency is TZS"
  },
  {
   "fieldname": "acquisition_cost_tzs",
   "fieldtype": "Float",
   "label": "Acquisition Cost (TZS)",
   "read_only": 1,
   "description": "Auto calculated from cost x exchange rate"
  },
  {
   "fieldname": "approval_section",
   "fieldtype": "Section Break",
   "label": "Approval"
  },
  {
   "fieldname": "approval_state",
   "fieldtype": "Data",
   "label": "Approval State",
   "read_only": 1,
   "default": "Draft"
  },
  {
   "fieldname": "approved_by",
   "fieldtype": "Link",
   "label": "Approved By",
   "options": "User",
   "read_only": 1
  },
  {
   "fieldname": "approval_date",
   "fieldtype": "Date",
   "label": "Approval Date",
   "read_only": 1
  },
  {
   "fieldname": "journal_entry",
   "fieldtype": "Link",
   "label": "Journal Entry",
   "options": "Journal Entry",
   "read_only": 1
},
  {
   "fieldname": "plots_summary_section",
   "fieldtype": "Section Break",
   "label": "Plots Summary"
  },
  {
   "fieldname": "total_plots",
   "fieldtype": "Int",
   "label": "Total Plots Created",
   "read_only": 1,
   "description": "Number of plots subdivided from this acquisition"
  },
  {
   "fieldname": "available_plots",
   "fieldtype": "Int",
   "label": "Available Plots",
   "read_only": 1,
   "description": "Plots not yet contracted or sold"
  },
  {
   "fieldname": "col_break_plots",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "reserved_plots",
   "fieldtype": "Int",
   "label": "Reserved Plots",
   "read_only": 1,
   "description": "Plots currently locked for a customer or under active contract"
  },
  {
   "fieldname": "delivered_plots",
   "fieldtype": "Int",
   "label": "Delivered / Closed Plots",
   "read_only": 1,
   "description": "Plots that have been delivered or title closed"
  },
  {
   "fieldname": "notes_section",
   "fieldtype": "Section Break",
   "label": "Notes"
  },
  {
   "fieldname": "notes",
   "fieldtype": "Long Text",
   "label": "Notes"
  },
  {
   "fieldname": "amended_from",
   "fieldtype": "Link",
   "label": "Amended From",
   "options": "Land Acquisition",
   "read_only": 1,
   "print_hide": 1
  }
 ],
 "permissions": [
  {
   "role": "Administrator",
   "read": 1,
   "write": 1,
   "create": 1,
   "delete": 1,
   "submit": 1,
   "cancel": 1,
   "amend": 1
  },
  {
   "role": "Sales",
   "read": 1,
   "write": 1,
   "create": 1
  },
  {
   "role": "Land Acquisition Approver",
   "read": 1,
   "write": 1,
   "submit": 1
  },
  {
   "role": "Finance",
   "read": 1
  },
  {
   "role": "Legal",
   "read": 1
  },
  {
   "role": "Auditor",
   "read": 1
  }
 ]
}
