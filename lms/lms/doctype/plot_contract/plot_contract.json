{
 "doctype": "DocType",
 "name": "Plot Contract",
 "module": "Lms",
 "autoname": "naming_series:",
 "naming_series": "CTR-.YYYY.-.####",
 "is_submittable": 1,
 "track_changes": 1,
 "fields": [
  {
   "fieldname": "naming_series",
   "fieldtype": "Select",
   "label": "Series",
   "options": "CTR-.YYYY.-.####"
  },
  {
   "fieldname": "contract_section",
   "fieldtype": "Section Break",
   "label": "Contract Details"
  },
  {
   "fieldname": "customer",
   "fieldtype": "Link",
   "label": "Customer",
   "options": "Customer",
   "reqd": 1
  },
  {
   "fieldname": "plot",
   "fieldtype": "Link",
   "label": "Plot",
   "options": "Plot Master",
   "reqd": 1,
   "description": "Only Available plots can be selected"
  },
  {
   "fieldname": "land_acquisition",
   "fieldtype": "Link",
   "label": "Land Acquisition",
   "options": "Land Acquisition",
   "read_only": 1,
   "description": "Auto-filled from the selected plot"
  },
  {
   "fieldname": "contract_date",
   "fieldtype": "Date",
   "label": "Contract Date",
   "reqd": 1
  },
  {
   "fieldname": "col_break_1",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "contract_status",
   "fieldtype": "Select",
   "label": "Contract Status",
   "options": "Draft\nActive\nCompleted\nCancelled\nTerminated",
   "default": "Draft",
   "read_only": 1
  },
  {
   "fieldname": "payment_completion_days",
   "fieldtype": "Int",
   "label": "Payment Completion Days",
   "reqd": 1,
   "default": "90",
   "description": "Number of days from contract date the customer has to complete full payment"
  },
  {
   "fieldname": "payment_deadline",
   "fieldtype": "Date",
   "label": "Payment Deadline",
   "read_only": 1,
   "description": "Auto-filled from contract date + payment completion days"
  },
  {
   "fieldname": "financials_section",
   "fieldtype": "Section Break",
   "label": "Financials"
  },
  {
   "fieldname": "selling_price",
   "fieldtype": "Float",
   "label": "Selling Price (TZS)",
   "read_only": 1,
   "description": "Auto-filled from Plot Master"
  },
  {
   "fieldname": "booking_fee_percent",
   "fieldtype": "Percent",
   "label": "Booking Fee %",
   "reqd": 1,
   "description": "Percentage of selling price required as booking fee for this contract"
  },
  {
   "fieldname": "government_share_percent",
   "fieldtype": "Percent",
   "label": "Government Share %",
   "reqd": 1,
   "description": "Government fee percentage for this contract — deducted at full payment completion"
  },
  {
   "fieldname": "col_break_2",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "booking_fee_amount",
   "fieldtype": "Float",
   "label": "Booking Fee Amount (TZS)",
   "read_only": 1
  },
  {
   "fieldname": "balance_due",
   "fieldtype": "Float",
   "label": "Balance Due (TZS)",
   "read_only": 1
  },
  {
   "fieldname": "booking_fee_invoice",
   "fieldtype": "Link",
   "label": "Booking Fee Invoice",
   "options": "Sales Invoice",
   "read_only": 1,
   "description": "Auto-created on contract submission"
  },
  {
   "fieldname": "payment_schedule_section",
   "fieldtype": "Section Break",
   "label": "Payment Schedule"
  },
  {
   "fieldname": "payment_schedule",
   "fieldtype": "Table",
   "label": "Payment Schedule",
   "options": "Plot Contract Payment"
  },
  {
   "fieldname": "payment_summary_section",
   "fieldtype": "Section Break",
   "label": "Payment Summary"
  },
  {
   "fieldname": "total_contract_value",
   "fieldtype": "Float",
   "label": "Total Contract Value (TZS)",
   "read_only": 1
  },
  {
   "fieldname": "total_paid",
   "fieldtype": "Float",
   "label": "Total Paid (TZS)",
   "read_only": 1
  },
  {
   "fieldname": "col_break_3",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "total_outstanding",
   "fieldtype": "Float",
   "label": "Total Outstanding (TZS)",
   "read_only": 1
  },
  {
   "fieldname": "government_fee_withheld",
   "fieldtype": "Float",
   "label": "Expected Government Fee (TZS)",
   "read_only": 1,
   "description": "Selling price × government share % — collected at full payment completion"
  },
  {
   "fieldname": "government_fee_entry",
   "fieldtype": "Link",
   "label": "Government Fee Journal Entry",
   "options": "Journal Entry",
   "read_only": 1,
   "description": "Auto-created when contract is fully paid"
  },
  {
   "fieldname": "forfeiture_entry",
   "fieldtype": "Link",
   "label": "Forfeiture Journal Entry",
   "options": "Journal Entry",
   "read_only": 1,
   "description": "Auto-created when contract is terminated; all funds paid by customer are forfeited (no refund)"
  },
  {
   "fieldname": "notes_section",
   "fieldtype": "Section Break",
   "label": "Notes"
  },
  {
   "fieldname": "notes",
   "fieldtype": "Long Text",
   "label": "Notes"
  },
  {
   "fieldname": "termination_reason",
   "fieldtype": "Long Text",
   "label": "Termination Reason",
   "read_only": 1,
   "description": "Reason recorded when contract was terminated due to non-payment or other cause"
  },
  {
   "fieldname": "amended_from",
   "fieldtype": "Link",
   "label": "Amended From",
   "options": "Plot Contract",
   "read_only": 1,
   "print_hide": 1
  }
 ],
 "permissions": [
  {
   "role": "Administrator",
   "read": 1,
   "write": 1,
   "create": 1,
   "delete": 1,
   "submit": 1,
   "cancel": 1,
   "amend": 1
  },
  {
   "role": "Sales",
   "read": 1,
   "write": 1,
   "create": 1,
   "submit": 1
  },
  {
   "role": "Finance",
   "read": 1
  },
  {
   "role": "Auditor",
   "read": 1
  }
 ]
}
